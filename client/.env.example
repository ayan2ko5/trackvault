# ============================================================
# FILE: client/.env
# PURPOSE: Frontend environment variables.
#          Variables must start with VITE_ to be accessible
#          in React code via import.meta.env.VITE_xxx
#
# NEVER put secrets here — this file is bundled into the
# browser JavaScript and is visible to all users.
# ============================================================

# Your backend API URL
# Development: your local Express server
VITE_API_URL=

# Production (uncomment and fill when you deploy to Railway):
# VITE_API_URL=https://your-app-name.up.railway.app/api